# =========================================================================
# GoAnsuran RAG Studio - Online Hybrid AI Configuration
# =========================================================================
# To connect your local RAG studio to a free online LLM provider (like
# OpenRouter or Groq), follow these steps:
#
# 1. Copy this file to a new file named ".env" in the same directory:
#    cp .env.example .env
#
# 2. Choose ONE of the providers below, uncomment its variables, and enter
#    your free API Key.
#
# 3. Re-run your docker stack:
#    docker compose up --build -d
#
# 4. Open Settings (gear icon in the app) and select your new online model!
# =========================================================================

# -------------------------------------------------------------------------
# OPTION A: OpenRouter (⭐⭐⭐⭐⭐ HIGHLY RECOMMENDED - Access Dozens of 100% Free Models!)
# -------------------------------------------------------------------------
# Get your free key instantly: https://openrouter.ai/keys
# Supported Free Models in our UI:
#   - meta-llama/llama-3-8b-instruct:free
#   - google/gemma-2-9b-it:free
#   - mistralai/mistral-7b-instruct:free
# -------------------------------------------------------------------------
ONLINE_API_URL=https://openrouter.ai/api/v1
ONLINE_API_KEY=your_free_openrouter_api_key_here

# -------------------------------------------------------------------------
# OPTION B: Groq Cloud (⭐⭐⭐⭐⭐ SUPER FAST - 500+ tokens/second Free Tier!)
# -------------------------------------------------------------------------
# Get your free key instantly: https://console.groq.com/keys
# Supported Free Models in our UI:
#   - llama3-8b-8192
#   - gemma2-9b-it
#   - mixtral-8x7b-32768
# -------------------------------------------------------------------------
# ONLINE_API_URL=https://api.groq.com/openai/v1
# ONLINE_API_KEY=your_free_groq_api_key_here
