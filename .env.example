# =========================================================================
# GoAnsuran RAG Chatbot - LLM API Configuration
# =========================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your API key
# 3. Run:  docker compose up -d
# 4. Seed:  node seed_goansuran.js && node seed_catalog.js
# =========================================================================

# -------------------------------------------------------------------------
# NVIDIA NIM API (DEFAULT - used by this project)
# -------------------------------------------------------------------------
# Get your key: https://build.nvidia.com/
# Working model: meta/llama-3.3-70b-instruct
# -------------------------------------------------------------------------
ONLINE_API_URL=https://integrate.api.nvidia.com/v1
ONLINE_API_KEY=nvapi-your-key-here

# PostgreSQL
DB_NAME=chatbox
DB_USER=chatbox
DB_PASSWORD=chatbox

# -------------------------------------------------------------------------
# ALTERNATIVE: Groq Cloud (fast inference, free tier)
# -------------------------------------------------------------------------
# Get your key: https://console.groq.com/keys
# Working models: llama-3.3-70b-versatile, llama3-70b-8192
# -------------------------------------------------------------------------
# ONLINE_API_URL=https://api.groq.com/openai/v1
# ONLINE_API_KEY=your_groq_api_key_here

# -------------------------------------------------------------------------
# ALTERNATIVE: OpenRouter (access many models, free tier available)
# -------------------------------------------------------------------------
# Get your key: https://openrouter.ai/keys
# Working models: meta-llama/llama-3.3-70b-instruct:free
# -------------------------------------------------------------------------
# ONLINE_API_URL=https://openrouter.ai/api/v1
# ONLINE_API_KEY=your_openrouter_api_key_here
